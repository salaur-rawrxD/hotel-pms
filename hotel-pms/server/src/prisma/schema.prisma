// Hotel PMS Prisma schema
//
// Local dev uses SQLite (no DB server required). For production set the
// provider to "postgresql", re-introduce enum types, and replace JSON-string
// fields like `amenities` with native arrays (see PRODUCTION_NOTES below).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ────────────────────────────────────────────────
// Models
// ────────────────────────────────────────────────
//
// Enum values are stored as strings and validated at the API layer via
// zod schemas. Valid values are documented on each field.

model Property {
  id          String    @id @default(cuid())
  name        String
  address     String
  phone       String?
  email       String?
  totalRooms  Int       @default(0)
  timezone    String    @default("America/Los_Angeles")
  createdAt   DateTime  @default(now())

  users       User[]
  roomTypes   RoomType[]
  ratePlans   RatePlan[]
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  name           String
  /// ADMIN | MANAGER | FRONT_DESK | HOUSEKEEPING
  role           String
  propertyId     String?
  createdAt      DateTime  @default(now())

  property       Property?            @relation(fields: [propertyId], references: [id])
  folioItems     FolioItem[]
  tasksAssigned  HousekeepingTask[]   @relation("TasksAssigned")
  reports        MaintenanceRequest[] @relation("ReportsBy")

  @@index([propertyId])
}

model RoomType {
  id             String   @id @default(cuid())
  name           String
  baseRate       Decimal
  maxOccupancy   Int      @default(2)
  /// JSON-encoded String[] on SQLite; switch to String[] on PostgreSQL.
  amenities      String   @default("[]")
  propertyId     String

  property       Property @relation(fields: [propertyId], references: [id])
  rooms          Room[]
  reservations   Reservation[]
  dailyRates     DailyRate[]

  @@index([propertyId])
}

model Room {
  id               String   @id @default(cuid())
  number           String   @unique
  floor            Int
  roomTypeId       String
  /// VACANT | OCCUPIED | DIRTY | CLEAN | OUT_OF_ORDER | DUE_IN | DUE_OUT
  status           String   @default("VACANT")
  currentGuestId   String?

  roomType         RoomType @relation(fields: [roomTypeId], references: [id])
  currentGuest     Guest?   @relation("CurrentOccupant", fields: [currentGuestId], references: [id])
  reservations     Reservation[]
  housekeepingTasks HousekeepingTask[]
  maintenance      MaintenanceRequest[]
  lostAndFound     LostAndFound[]

  @@index([roomTypeId])
  @@index([status])
}

model Guest {
  id             String     @id @default(cuid())
  firstName      String
  lastName       String
  email          String?    @unique
  phone          String?
  nationality    String?
  idType         String?
  idNumber       String?
  /// NONE | BRONZE | SILVER | GOLD | PLATINUM
  loyaltyTier    String     @default("NONE")
  loyaltyPoints  Int        @default(0)
  notes          String?
  createdAt      DateTime   @default(now())

  reservations   Reservation[]
  currentRooms   Room[]     @relation("CurrentOccupant")
}

model Reservation {
  id                 String    @id @default(cuid())
  confirmationNumber String    @unique
  guestId            String
  roomId             String?
  roomTypeId         String
  checkIn            DateTime
  checkOut           DateTime
  adults             Int       @default(1)
  children           Int       @default(0)
  /// CONFIRMED | CHECKED_IN | CHECKED_OUT | CANCELLED | NO_SHOW
  status             String    @default("CONFIRMED")
  /// DIRECT | EXPEDIA | BOOKING | AIRBNB | CORPORATE | WALKIN
  source             String    @default("DIRECT")
  ratePlanId         String?
  totalAmount        Decimal
  depositPaid        Decimal   @default(0)
  specialRequests    String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  guest     Guest      @relation(fields: [guestId], references: [id])
  room      Room?      @relation(fields: [roomId], references: [id])
  roomType  RoomType   @relation(fields: [roomTypeId], references: [id])
  ratePlan  RatePlan?  @relation(fields: [ratePlanId], references: [id])
  folio     FolioItem[]

  @@index([guestId])
  @@index([roomId])
  @@index([status])
  @@index([checkIn])
}

model RatePlan {
  id                  String   @id @default(cuid())
  name                String
  description         String?
  baseRate            Decimal
  isRefundable        Boolean  @default(true)
  breakfastIncluded   Boolean  @default(false)
  propertyId          String

  property            Property @relation(fields: [propertyId], references: [id])
  reservations        Reservation[]

  @@index([propertyId])
}

model DailyRate {
  id                   String   @id @default(cuid())
  roomTypeId           String
  date                 DateTime
  rate                 Decimal
  minLOS               Int      @default(1)
  maxLOS               Int      @default(30)
  closedToArrival      Boolean  @default(false)
  closedToDeparture    Boolean  @default(false)
  isBlocked            Boolean  @default(false)

  roomType             RoomType @relation(fields: [roomTypeId], references: [id])

  @@unique([roomTypeId, date])
  @@index([date])
}

model FolioItem {
  id             String        @id @default(cuid())
  reservationId  String
  description    String
  amount         Decimal
  /// ROOM | FOOD | BEVERAGE | PARKING | OTHER | DISCOUNT | TAX
  type           String
  postedAt       DateTime      @default(now())
  postedById     String?

  reservation    Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  postedBy       User?         @relation(fields: [postedById], references: [id])

  @@index([reservationId])
}

model HousekeepingTask {
  id             String    @id @default(cuid())
  roomId         String
  assignedToId   String?
  /// PENDING | IN_PROGRESS | INSPECTED | DONE
  status         String    @default("PENDING")
  /// CHECKOUT | STAY_OVER | DEEP_CLEAN
  taskType       String    @default("CHECKOUT")
  priority       Int       @default(3)
  notes          String?
  createdAt      DateTime  @default(now())
  startedAt      DateTime?
  completedAt    DateTime?

  room           Room      @relation(fields: [roomId], references: [id])
  assignedTo     User?     @relation("TasksAssigned", fields: [assignedToId], references: [id])
  checklist      RoomChecklist?

  @@index([roomId])
  @@index([assignedToId])
  @@index([status])
}

model MaintenanceRequest {
  id              String    @id @default(cuid())
  roomId          String
  reportedById    String
  reportedBy      String    @default("")
  description     String
  /// LOW | MEDIUM | HIGH
  severity        String    @default("LOW")
  /// OPEN | IN_PROGRESS | RESOLVED | CLOSED
  status          String    @default("OPEN")
  /// JSON-encoded string[] of image URLs.
  images          String?
  createdAt       DateTime  @default(now())
  resolvedAt      DateTime?
  resolvedBy      String?

  room            Room      @relation(fields: [roomId], references: [id])
  reporter        User      @relation("ReportsBy", fields: [reportedById], references: [id])

  @@index([roomId])
  @@index([status])
  @@index([severity])
}

// ────────────────────────────────────────────────
// Housekeeping module
// ────────────────────────────────────────────────

model ChecklistTemplate {
  id         String          @id @default(cuid())
  name       String
  /// CHECKOUT | STAY_OVER | DEEP_CLEAN — mirrors HousekeepingTask.taskType.
  taskType   String          @default("CHECKOUT")
  roomType   String?
  propertyId String
  createdAt  DateTime        @default(now())

  items      ChecklistItem[]

  @@index([propertyId])
  @@index([taskType])
}

model ChecklistItem {
  id         String            @id @default(cuid())
  templateId String
  label      String
  /// Bathroom | Bedroom | General
  category   String
  order      Int               @default(0)

  template   ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

model RoomChecklist {
  id            String              @id @default(cuid())
  taskId        String              @unique
  completedAt   DateTime?
  inspectedById String?
  inspectedAt   DateTime?
  createdAt     DateTime            @default(now())

  task          HousekeepingTask    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  items         RoomChecklistItem[]

  @@index([taskId])
}

model RoomChecklistItem {
  id          String        @id @default(cuid())
  checklistId String
  label       String
  category    String
  order       Int           @default(0)
  isChecked   Boolean       @default(false)
  checkedAt   DateTime?

  checklist   RoomChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId])
}

model LostAndFound {
  id          String    @id @default(cuid())
  roomId      String
  description String
  foundBy     String
  foundAt     DateTime  @default(now())
  /// UNCLAIMED | CLAIMED | RETURNED | DONATED
  status      String    @default("UNCLAIMED")
  guestName   String?
  claimedAt   DateTime?
  notes       String?

  room        Room      @relation(fields: [roomId], references: [id])

  @@index([roomId])
  @@index([status])
}

model SupplyRequest {
  id          String    @id @default(cuid())
  requestedBy String
  items       String
  quantity    String
  /// NORMAL | URGENT
  urgency     String    @default("NORMAL")
  /// PENDING | FULFILLED
  status      String    @default("PENDING")
  notes       String?
  createdAt   DateTime  @default(now())
  fulfilledAt DateTime?

  @@index([status])
  @@index([urgency])
}
