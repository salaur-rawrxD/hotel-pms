# ─── Database ─────────────────────────────────────────────────────────────
# Copy this file to .env and replace placeholders with values from Supabase:
#   Dashboard → Project Settings → Database → Connection string
#
# DATABASE_URL — Transaction pooler (port 6543), used by the running app.
#   Use the "Transaction" pooler URI. For Prisma + PgBouncer add:
#   ?pgbouncer=true&connection_limit=1
#   Supabase may show user as: postgres.[PROJECT-REF]
#
# DIRECT_URL — Used by prisma migrate / db pull / seed (must not use transaction pooler).
#   Prefer: direct host db.[REF].supabase.co:5432 (from "Direct connection" in dashboard).
#   Alternative (IPv4 / some networks): Session pooler on port 5432 — same user as transaction pooler:
#   postgresql://postgres.[REF]:[PASSWORD]@aws-1-us-west-2.pooler.supabase.com:5432/postgres
#
DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres"

# If you only have one connection string, set both variables to the same URI.

# ─── Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET="your_strong_secret_here"
JWT_EXPIRES_IN="8h"

# ─── Server ───────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3001

# ─── CORS ─────────────────────────────────────────────────────────────────
# Production: set CLIENT_URL to your deployed frontend origin (Vercel).
# Local: localhost:5173 / 4173 are always allowed; optional legacy CLIENT_ORIGIN.
CLIENT_URL="https://your-frontend.vercel.app"
CLIENT_ORIGIN="http://localhost:5173"
